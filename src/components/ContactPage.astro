---
---

<div class="mx-auto px-8 md:px-12 lg:px-16">
    <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-4"
    >
  <!-- Required hidden input -->
  <input type="hidden" name="form-name" value="contact" />

  <!-- Spam trap -->
  <p class="hidden">
    <label>
        Don’t fill this out:
        <input name="bot-field" />
    </label>
  </p>

  <div>
    <label>Name</label>
    <input
        type="text"
        name="name"
        required
        class="w-full border p-2"
    />
  </div>

  <div>
    <label>Email</label>
    <input
        type="email"
        name="email"
        required
        class="w-full border p-2"
    />
  </div>

  <div>
    <label>Message</label>
    <textarea
        name="message"
        required
        class="w-full border p-2"
    ></textarea>
  </div>

  <button
    type="submit"
    class="px-4 py-2 bg-secondary text-white"
  >
    Send Message
  </button>
</form></form>

</div>